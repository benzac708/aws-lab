project_name       = "zachara"
environment        = "dev"
aws_region         = "us-east-1"
vpc_cidr           = "10.0.0.0/16"
availability_zones = ["us-east-1a", "us-east-1b"]

public_subnet_cidrs  = ["10.0.1.0/24", "10.0.2.0/24"]
private_subnet_cidrs = ["10.0.11.0/24", "10.0.12.0/24"]
data_subnet_cidrs    = ["10.0.21.0/24", "10.0.22.0/24"]

# Tighten this before apply if you know your current public IP.
allowed_ssh_cidr      = "0.0.0.0/0"
bastion_instance_type = "t3.micro"
ssh_public_key_path   = "~/.ssh/id_ed25519.pub"

# Optional: set this only if you want to pin a specific AMI.
# bastion_ami = "ami-xxxxxxxxxxxxxxxxx"

tags = {
  Owner = "zachara"
}
